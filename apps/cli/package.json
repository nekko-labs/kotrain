{
  "name": "@kotrain/cli",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "description": "Kotrain CLI + MCP server, drive your local agent from the terminal or other tools (Claude Code, Codex, …).",
  "bin": {
    "kotrain": "./dist/index.js",
    "opaw": "./dist/index.js"
  },
  "main": "./dist/run.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@kotrain/host": "*",
    "@kotrain/shared": "*"
  }
}

{
  "name": "@kotrain/server",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Kotrain self-hosted web server, same engine + UI as the desktop app.",
  "main": "./dist/index.js",
  "bin": {
    "kotrain": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "bundle": "node scripts/bundle.mjs"
  },
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "@fastify/websocket": "^11.3.0",
    "@kotrain/cli": "*",
    "@kotrain/host": "*",
    "@kotrain/shared": "*",
    "fastify": "^5.10.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.5"
  }
}
